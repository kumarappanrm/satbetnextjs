$(document).ready(function () {
  
  const step = 1;

function validateInput(value) {
    return Math.max(0, parseInt(String(value).replace(/[^0-9]/g, ''), 10) || 0);
}

function updateInputField(input, value) {
  if(value >0){ input.val(value); }

    if (window.location.pathname.includes('/deposit')) {
        $('#bank_amount').val(value);
    }
    var deposit_amt = input.val();
    var promoMinAmt = parseFloat(
        input.closest('.text_wrper').find('input[name="promo_code"]').attr('data-min-amt') ||
        input.closest('.text_wrper').find('input[name="razopay_promo"]').attr('data-min-amt')
    ) || 0; 
   
    var depstAmt = parseFloat(deposit_amt) || 0; // Convert to number
    var promoAmt = parseFloat(promoMinAmt) || 0; // Convert to number
    check_depositpromo_limit(depstAmt , promoAmt,input.attr('id'));
}

$(document).on('click', '#deposit-amount-minus', function () {
    const input = $(this).siblings('input.deposit_field');
    updateInputField(input, validateInput(input.val()) - step);
});

$(document).on('click', '#deposit-amount-plus', function () {
    const input = $(this).siblings('input.deposit_field');
    updateInputField(input, validateInput(input.val()) + step);
});

$(document).on('input', '.deposit_field', function () {
    $(this).val(validateInput($(this).val()));
});

function check_depositpromo_limit(depstAmt, promoAmt,inputid) {
  if (depstAmt > 0 && promoAmt > 0) {
    if (depstAmt < promoAmt) {
      $("#"+inputid+"-error")
            .html('Enter at least ' + promoAmt + ' to apply the promo.')
            .css('display', 'block');
    } else {
      $("#"+inputid+"-error").css('display', 'none');
    }
} else {
  $("#"+inputid+"-error").css('display', 'none');
}

}

  // File upload
  $('#uploadfiles_trigger').on('click', function () {
    $('#uploadfiles_right_input').click();
  });

  // Handle file selection
  $('#uploadfiles_right_input').on('change', function () {
    const file = this.files[0];
    const errorText = $('.errortext');

    if (file) {
      alert('File uploaded successfully: ' + file.name);
    }
  });
});

