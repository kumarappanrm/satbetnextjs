$(document).ready(function(){
	"use strict";
 
	/*
	==============================================================
	 Back to Top  Script Start
	==============================================================
	*/
	$(window).scroll(function () {
		if ($(this).scrollTop() > 400) {
		  	$('.go-up').fadeIn();
		} else {
		  	$('.go-up').fadeOut();
		}
	});
	$('.go-up').on('click', function () {
		$("html, body").animate({
		  scrollTop: 0
		}, 600);
		return false;
	});

  /*
    =======================================================================
         Tool Tip Script Script
    =======================================================================
  */
  
    $('[data-toggle="tooltip"]').tooltip();

 
    
    /*
    ============================================================== 
        DL Responsive Menu
    ============================================================== 
    */
    if(typeof($.fn.dlmenu) == 'function'){
      $('#sat-responsive-navigation').each(function(){
        $(this).find('.dl-submenu').each(function(){
        if( $(this).siblings('a').attr('href') && $(this).siblings('a').attr('href') != '#' ){
          var parent_nav = $('<li class="menu-item sat-parent-menu"></li>');
          parent_nav.append($(this).siblings('a').clone());
          
          $(this).prepend(parent_nav);
        }
        });
        $(this).dlmenu();
      });
    }
	
	
	$('.main-slider').infiniteslide({
			pauseonhover: false,
			responsive: true
		});
		
		
	 /*
    ============================================================== 
        Change pwd 
    ============================================================== 
    */	
  $('#change_pwd').modal('show').unbind( "click");
  
	$(".number_only").on("input keyup", function() {
    this.value = this.value.replace(/\D/g, '');
  });
 }); 

