      $(document).ready(function () {
        $('.uploadfile').on('change', function () {
            const file = this.files[0];
            const imgPreview = $(this).siblings('img');
            const oldSrc = imgPreview.attr('data-old');
            const maxFileSize = parseInt($(this).attr('maxlength'), 10);
            const inputBox = $(this).parent();
            // Check if a file is selected
            if (!file) {
                 $(this).val(''); // Reset the file input
                imgPreview.attr('src', oldSrc); // Revert to the previous image
                swal.fire("No file selected.");
                triggerAlert(inputBox);
                return;
            }
    
            // Validate file type
            if (!file.name.match(/\.(png|jpg|jpeg)$/)) {
            swal.fire("Invalid file format. Please upload a JPEG, JPG, or PNG image.");
            $(this).val(''); // Reset the file input
            imgPreview.attr('src', oldSrc); // Revert to the previous image
            triggerAlert(inputBox);
            return;
            }
            // Validate file size
            if (maxFileSize && file.size > maxFileSize) {
                swal.fire("File size exceeds the 2 MB limit. Please upload a smaller file.");
                $(this).val(''); // Reset the file input
                imgPreview.attr('src', oldSrc); // Revert to the previous image
                triggerAlert(inputBox);
                return;
            }
    
            // Display the selected image
            const reader = new FileReader();
            reader.onload = function (e) { imgPreview.attr('src', e.target.result);};
            reader.readAsDataURL(file);
    
        });
        $('.upload_file_btn').on('click', function () {
            $(this).siblings('input.uploadfile').click();
        });
    
        $('.transfer_details_content .copy_button').click(function () {
              var $this = $(this);
              $this.attr('data-tooltip', 'copied!');
              $this.attr('data-tooltip-active', 'true');
              setTimeout(function() {
                  $this.attr('data-tooltip-active', 'false');
              }, 1500);
        });
    });

$(document).ready(function () {
var swiperContainer = document.querySelector('.swiper-container.buychips');
var slidesCount = (swiperContainer != null) ? swiperContainer.querySelectorAll('.swiper-slide').length : 0;	
if ($('.swiper-container.buychips').length) {
	var swiper = new Swiper('.swiper-container.buychips', {
      grabCursor: true,
      centeredSlides: slidesCount <= 2,
	  infinite: slidesCount >= 2,
	  loop: slidesCount >= 2,
      slidesPerView: '2',
      spaceBetween: 17,
	  navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
      },
	  autoplay: {
        delay: 2500,
        disableOnInteraction: false,
      },
      breakpoints: {
        640: {
          slidesPerView: 1,
        },
        767: {
          slidesPerView: 1,
        },
        1024: {
          slidesPerView: 1,
        },
      }
    });
  }
	if (slidesCount < 2) {
  $(".swiper-button-prev").hide();
  $(".swiper-button-next").hide();
}
  $('.deposit-pad-mob a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
    // Get the target tab's ID
    var tabId = $(e.target).attr('href');
    // Find the Swiper container within the target tab
    var swiperContainer = $(tabId).find('.swiper-container');

    // Initialize Swiper if not already initialized
    if (!swiperContainer.hasClass('swiper-initialized') && $('.swiper-container.buychips').length) {
      var swiper = new Swiper('.swiper-container.buychips', {
      grabCursor: true,
      centeredSlides: slidesCount <= 2,
	  infinite: slidesCount >= 2,
	  loop: slidesCount >= 2,
      slidesPerView: '2',
      spaceBetween: 17,
	  navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
      },
	  autoplay: {
        delay: 2500,
        disableOnInteraction: false,
      },
      breakpoints: {
        640: {
          slidesPerView: 1,
        },
        767: {
          slidesPerView: 1,
        },
        1024: {
          slidesPerView: 1,
        },
      }
	  
	  
	  
    });
	
	if (slidesCount < 2) {
  $(".swiper-button-prev").hide();
  $(".swiper-button-next").hide();
}

      // Mark the Swiper container as initialized
      swiperContainer.addClass('swiper-initialized');
    }
  });

  $('.deposit-pad-mob a[data-toggle="tab"]').on('hide.bs.tab', function (e) {
    // Get the target tab's ID
    var tabId = $(e.target).attr('href');
    // Find the Swiper container within the target tab
    var swiperContainer = $(tabId).find('.swiper-container');

    // Destroy Swiper if it was initialized
    if (swiperContainer.hasClass('swiper-initialized')) {
      swiperContainer.removeClass('swiper-initialized');
      swiperContainer[0].swiper.destroy();
    }
  });
  
});

	
	 
	
