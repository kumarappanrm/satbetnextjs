 $(document).ready(function(){
$(".submenu_list li").click(function(){
  $(".submenu_list li").removeClass("active");
  $(this).addClass("active");
  $(".submenu_list").scrollCenter(".active", 1500);
});

jQuery.fn.scrollCenter = function(elem, speed) {

  var _defaultLeft = $(".submenu_list").position().left;
  var active = $(".submenu_list").find(elem); 
  var activeWidth = active.outerWidth() / 2; 
  var pos = (active.position().left) + activeWidth;
  var elpos = $(".submenu_list").scrollLeft();
  var elW = $(".submenu_list").outerWidth();
  pos = pos + elpos - elW / 2; 
$(".submenu_list").animate({
   scrollLeft: pos
 },0, 'linear');
 return this;
};
});	
	
$(document).on('click', '.toggle-password-login', function() {

  $(this).toggleClass("fa-eye fa-eye-slash");
  
  var input = $("#user-password");
  input.attr('type') === 'password' ? input.attr('type','text') : input.attr('type','password')
});  

