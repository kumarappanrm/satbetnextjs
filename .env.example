# --- Site URL (canonical, Open Graph base, metadata) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base URL of the app / API host (nav links, fetches)
NEXT_PUBLIC_BASE_URL=http://localhost:3000/

# Casino catalog: `src/app/casino-games/page.tsx` reads `public/data/casino-games.json` at build time
# (no client fetch). Regenerate from saved HTML: `npm run catalog:build` (needs `casino-games_files/casino-games.html`).
# Client fetch helper (optional / future): NEXT_PUBLIC_CASINO_GAMES_DATA_URL=https://api.example.com/v1/casino-games

# Demo user credentials
NEXT_PUBLIC_DEMO_USERNAME=demo
NEXT_PUBLIC_DEMO_PASSWORD=demo@123

# CDN path for assets (optional if serving from /public)
NEXT_PUBLIC_CDN_ASSETS_PATH=/

# --- Feature flags (set to false or 0 to disable) ---

# Google Tag Manager (loads published tags: Clarity, GA4, etc.)
# NEXT_PUBLIC_ENABLE_GTM=false
NEXT_PUBLIC_GTM_ID=GTM-TM9BSSML

# Search Console verification meta tag
# NEXT_PUBLIC_ENABLE_GOOGLE_SITE_VERIFICATION=false
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_token_here

# CSP: upgrade-insecure-requests (can block some http:// local asset tests)
# NEXT_PUBLIC_ENABLE_CSP_UPGRADE_INSECURE=false

# Allow search engines to index (use false on staging)
# NEXT_PUBLIC_ENABLE_ROBOTS_INDEX=false

# Third-party exchange iframe (widgetjf.goldenspin.co)
# NEXT_PUBLIC_ENABLE_EXCHANGE_IFRAME=false

# Remote game thumbnails (prod.bollytech.com) — off uses local placeholder tiles
# NEXT_PUBLIC_ENABLE_REMOTE_GAME_CDN_IMAGES=false
# Bottom-nav chat bot button (Tawk.to — only works if Tawk script is injected elsewhere)
# NEXT_PUBLIC_ENABLE_TAWK_CHAT=false

