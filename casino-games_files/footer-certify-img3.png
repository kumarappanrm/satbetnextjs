  function capturePopup() {

const element = document.getElementById('one_click_signup');
$('#onclick_header, #oneclickForm').hide();
    html2canvas(element, { backgroundColor: null }).then(canvas => {
        // Convert canvas to JPEG
        const link = document.createElement('a');
        link.download = 'signup.jpg';
        link.href = canvas.toDataURL('image/jpeg', 1.0); // 1.0 = high quality
        link.click();
    });
   $('#onclick_header, #oneclickForm').show();
}

  function checkBoth() {
    //   if ($('.age_box').is(':checked') && $('.terms_box').is(':checked')) {
        // var username = "satuser" + Math.floor(Math.random() * 100000);
        var username = '';
        var password = generatePassword();

        var c_password = password;
        var one_click_signup = 1;
        var google_id = 1;
        let number = $('#one_click_mobile_no').val();
        let mobile_no = number.replace(/-/g, "");

        var csrfName = 'csrf_token'; // CSRF Token name
        var csrfHash = '2e10e9c5aee93879c6b255903a1be7ba';
        $.ajax({
          url: 'https://devenubuntu.satbet.com/user/register/check_oneclickuserip_registerlimit',
          type: 'post',
          dataType:'json',
          data: {[csrfName]: csrfHash},
          success: function(response) {
             if(response.status === 0){
            $('#Login').modal('hide');
            $('.submit-loader').css('display','none');
            $('#onclickbtn').css('display','block')
            Swal.fire({ 
            title: `<span style="color: #F40000;">Registration Failed!</span>`, // Title appears above
            html: `<p>${response.error_message}</p>`, // Error message below title
            imageUrl: "https://qaasset.satbet.com/images/close_1.png",
            imageWidth: 50,
            imageHeight: 50,
            confirmButtonText: "Continue",
            customClass: {
                confirmButton: "custom-swal-button"
            }
            });

              }
            else{
              $('.oneclick-confirmation-error').html('');
              $.ajax({
                url: 'https://devenubuntu.satbet.com/user/register/register',
                type: 'post',
                data: {
                  username: username,
                  password: password,
                  c_password: c_password,
                  one_click_signup: one_click_signup,
                  google_id : google_id,
                  mobile_no: mobile_no,
                  [csrfName]: csrfHash
                },
                beforeSend: function() {
                    $('.submit-loader').css('display','block');
                    $('#onclickbtn').css('display','none');
                },
                success: function(response) {
                  response = JSON.parse(response);
                  if (response && response.userId) {
                    username= response.userName;
                    console.clear();
                    console.table(response)
                    swal.close();
                    oneclick_send_credentials(username , password);
                    $('.one_click_mobile_confirm').hide()
                    $('.satbet-container').css('display','none');
                    $('.one_click_wrapper').css('display','block');
                    $('#Login').modal('show');
                    $('.onclick_username').text(username);
                    $('.onclick_password').text(password);
                  } else {
                    if(response.status){
                        Swal.fire({ title: "Registration Failed!", text: response.error, icon: "error" });
                    }else{
                        Swal.fire({ title: "Registration Failed!", text: response.error_msg, icon: "error" });
                    }
                    $('.submit-loader').css('display','none');
                    $('#onclickbtn').css('display','block');
                    $('.age_box,.terms_box').prop('checked', false);
                  }
                },
              });
            }
          }
          });
    //   }
    };

    $('#oneclick_register').on('click',()=>{
         $('.satbet-container').css('display','none');
        $('.one_click_mobile_confirm').css('display','block');
    })
    function generatePassword() {
        const upperCase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
        const lowerCase = 'abcdefghijklmnopqrstuvwxyz';
        const specialChars = '@';
        const numbers = '0123456789';

        let password = '';
        password += upperCase[Math.floor(Math.random() * upperCase.length)];
        password += specialChars[Math.floor(Math.random() * specialChars.length)];
        password += lowerCase[Math.floor(Math.random() * lowerCase.length)];
        password += numbers[Math.floor(Math.random() * numbers.length)];
        for (let i = 0; i < 4; i++) {
            const charSet = Math.random() < 0.5 ? lowerCase : numbers;
            password += charSet[Math.floor(Math.random() * charSet.length)];
        }
        return password.split('').sort(() => 0.5 - Math.random()).join('');
    }

