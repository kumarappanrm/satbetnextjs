  document.addEventListener("DOMContentLoaded", () => {
  const checkbox = document.querySelector(".custom-checkbox");
  const backdrop = document.getElementById("backdrop-overlay");
  const whatsappTrigger = document.getElementById("custom-menu-wa");
  const whatsappClickPopup = document.getElementById("whatsapp_click_popup");

  checkbox.addEventListener("change", () => {
    if (checkbox.checked) {
      backdrop.style.display = "block";
    } else {
      backdrop.style.display = "none";
      whatsappClickPopup.style.display = "none";
    }
  });

  backdrop.addEventListener("click", () => {
    checkbox.checked = false;
    backdrop.style.display = "none";
    whatsappClickPopup.style.display = "none";
  });

});

$(document).on('click','.custom-menu-item',function(){
if($(this).attr('id') == 'custom-menu-wa'){
$("#whatsapp_click_popup").toggle();
}else{
$("#whatsapp_click_popup").hide();
}
});

