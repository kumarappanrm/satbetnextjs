<!-- End-Forgot-password Popup -->
<script>

	$.validator.addMethod("forgotemailexist",
    function(value, element) {
			$('.forgot_password').parent().find('.submit-loader').css('display','block');
			$('.forgot_password').css('display','none');
      var result = false;
      var url = "https://devenubuntu.satbet.com/user/register/check_useremail_exists";
      $.ajax({
        type:"POST",
        async: false,
        url: url,
        data:{emailid : value,[csrfName]:csrfHash},
				beforeSend: function() {
						
    			},
        success: function(msg) {
          msg = JSON.parse(msg);
					// $('.forgot_password').parent().find('.submit-loader').css('display','none');
					// 	$('.forgot_password').css('display','inline-block');
					if(msg.url) { window.location.href = response.url; return false; } 
         if($.trim(msg.value) == "exists"){
					 result = true;
				 }else{
					 	$('.forgot_password').parent().find('.submit-loader').css('display','none');
						$('.forgot_password').css('display','inline-block');
					 result = false;
				 } 
        }
      });
      return result;
    },
	"Email address not exists"
  );



    $("#forgotPassword").validate({
			onkey:false,
			onfocusout:false,
        rules: {
            "email": {
                required: true,
                email: true,
                forgotemailexist: true,
            }
        },
        messages: {
            "email": {
                required: "Enter an email",
                email: "Enter a valid Email Address (Example : John@gmail.com)",
            }
        },
        submitHandler: function(form,e) { // for demo
				e.preventDefault();
          $.ajax({
            type: 'post',
            url: 'https://devenubuntu.satbet.com/user/forgotpassword',
            datatype:'Json',
            data: $(form).serialize(),
						beforeSend: function() {
							$('.forgot_password').parent().find('.submit-loader').css('display','block');
							$('.forgot_password').css('display','none');
    			},
            success: function(response) {   
							response = JSON.parse(response);
							if(response.url) { window.location.href = response.url; return false; } 
							if(response.error == false){
								$('.forgotpassword-error').removeClass('error-msg').addClass('success-msg');
								$('.forgotpassword-error').html(response.message);
								$('#forgotPassword')[0].reset();
								$('.forgotpassword-error').css('display','block');
								$('.forgot_password').parent().find('.submit-loader').css('display','none');
								$('.forgot_password').css('display','inline-block');
					
						setTimeout(function(){
						$('.error_msg').css('display','none');
						$('#changepwd_popup').modal('hide');
				
						$('.forgotpassword-error').css('display','none');
					},3000)
					}else{
					
						$('.forgotpassword-error').removeClass('success-msg').addClass('error-msg');
						$('.forgotpassword-error').html(response.message);
						$('.forgotpassword-error').css('display','block');
						
						setTimeout(function(){
						$('.error_msg').css('display','none');
					},3000)
					}
					$('.error_msg').css('display','block');
            }
          });
          return false;
        }
    });



    
</script>
    <script>
$(document).ready(function () {
    $("form[name='formChangePassword']").validate({
        rules: {
            newpassword: {
                required: true,
                minlength: 8,
                maxlength: 20,
            },
             confirm_password: {
                required: true,
                equalTo: "#newpassword"
            }
        },
        messages: {
              "newpassword": {
                  required: "New password is empty"
              },
              "confirm_password": {
                  required: "Confirm password is empty"
              },
        },
        submitHandler: function(form, e) {
          e.preventDefault();
          $.ajax({
            url: 'https://devenubuntu.satbet.com/user/Forgotpassword/resetpasslink',
            type: 'POST',
            datatype:'json',
            data: $("#formChangePassword").serialize(),
            success: function(response) {   
              console.log(response, 'ResetPasswordResponse');
              var ResponseDecode  = JSON.parse(response);
              var ErrorMsg   = ResponseDecode.error_message;
              var Status   = ResponseDecode.status;
                if( Status === 1)
                {   
                    $('#submit_forgotpassword').attr('disabled','true');
                    $('.reset-link-msg').addClass('alert-success');
                    $('.reset-link-msg').removeClass('alert-danger');
                    $('.reset-link-msg').html(ErrorMsg);
                    $('#reset-link-div').show();
                    // $('#error_result').fadeIn().html("<div class='alert alert-success'>"+ErrorMsg+"</div>");
                    setTimeout(function() {
                      $('#reset-link-div').fadeOut("slow");
                      var url="https://devenubuntu.satbet.com/";
                      window.location.href=url;
                    }, 3000 );                    
                }else{
                    $('.reset-link-msg').removeClass('alert-success');
                    $('.reset-link-msg').addClass('alert-danger');
                    $('.reset-link-msg').html(ErrorMsg);
                    $('#reset-link-div').show();
                    // $('#error_result').fadeIn().html("<div class='alert alert-danger'>"+ErrorMsg+"</div>");
                    setTimeout(function() {
                            $('#reset-link-div').fadeOut("slow");
							var url="https://devenubuntu.satbet.com/";
							// window.location.href=url;
                    }, 3000 );                    
                }
                
            }
          });
          return false;
        }
    });

});
</script>
