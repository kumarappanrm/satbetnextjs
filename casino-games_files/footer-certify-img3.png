<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>

    $('.open-eye').click(function(){
        $('#password').attr('type', 'password');
        $(this).css('display','none');
        $('.close-eye').css('display','block');
    });
    $('.close-eye').click(function(){
        $('#password').attr('type', 'text');
        $(this).css('display','none');
        $('.open-eye').css('display','block');
    });

    document.addEventListener("DOMContentLoaded", () => {
        const loginTab = document.getElementById("login-tab");
        const signupTab = document.getElementById("signup-tab");
        const loginForm = document.getElementById("login-form");
        const registerForm = document.getElementById("signup-form");


        loginTab.addEventListener("click", () => {
            loginTab.classList.add("satbet-tab-active");
            signupTab.classList.remove("satbet-tab-active");
            loginForm.classList.add("satbet-form-active");
            registerForm.classList.remove("satbet-form-active");
        });

        signupTab.addEventListener("click", () => {
            signupTab.classList.add("satbet-tab-active");
            loginTab.classList.remove("satbet-tab-active");
            loginForm.classList.remove("satbet-form-active");
