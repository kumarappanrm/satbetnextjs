<script>
  $(document).ready(function () {
    $(document).on("click touchstart", function (event) {
        if (!$(event.target).closest(".user_profile_menu.userdtls_hdr22").length) {
            $(".user_profile_menu.userdtls_hdr22").removeClass("open");
            $(".userdtls_hdr22_dropdown").removeClass("show");
        }
    });

    // Prevent the event from closing when clicking inside the dropdown
    $(".user_profile_menu.userdtls_hdr22").on("click touchstart", function (event) {
        event.stopPropagation();
    });
});

</script>


