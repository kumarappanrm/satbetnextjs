                <label class="unique-switch">
                        <input type="checkbox" id="termsCheck" name="termsCheck" class="form-check-input terms_box"  onchange="checkBoth(this.value)" />
                        <span class="unique-slider round"></span>
                    </label>
                <label class="form-check-label text-dark" for="termsCheck" style="color: #000002;text-align: left;font-size: 14px;">
                    I agree with <b>Terms & Conditions</b>
                </label>
                </div>
            </div>
            </form>
        `,
        customClass:'one_click_confirmation_box',
        showCancelButton: false,
        showConfirmButton: false
        });
}



