<script>
    
    $(document).ready(function() {
        $('#sendotp').css('display','none');
        let totalSeconds = 120; // 2 minutes
        let interval = null;     // store interval

        function startTimer() {
            // Reset timer
            totalSeconds = 120;

            // Clear any previous interval
            if (interval) {
                clearInterval(interval);
            }

            // Show timer container
            $('#timer_otp').attr('style', 'display: flex !important; align-items:center; gap:8px;');

            interval = setInterval(function() {
                let minutes = Math.floor(totalSeconds / 60);
                let seconds = totalSeconds % 60;

                minutes = minutes < 10 ? '0' + minutes : minutes;
                seconds = seconds < 10 ? '0' + seconds : seconds;

                $('#timer').css('color','red').text(minutes + ':' + seconds);

                if (totalSeconds <= 0) {
                    clearInterval(interval);
                    $('#verify_otp').hide();
                    $('#timer').css('color','red').text("Time's up!");
                }

                totalSeconds--;
            }, 1000);
        }
    $('#sendotp').click(()=>{
        $('#otp_response-error').text('')
        if ($('#mobile_no').val().trim() === '' || $('#mobile_no').val().length < 10 || $('#reg_username').val().trim() === '') {
            // Mobile number validation
            if ($('#mobile_no').val().trim() === '') {
                $('#mobile_no-error').text('').text('Enter your mobile number');
            } else if ($('#mobile_no').val().length < 10) {
                $('#mobile_no-error').text('').text('Mobile number must be 10 digits');
            } else if(!/^[6-9]/.test($('#mobile_no').val().trim())){
                $('#mobile_no-error').text('').text("Mobile number must start with 9,8,7,6");
            } else{
                $('#mobile_no-error').text('');
            }
            // Username validation
            if ($('#reg_username').val().trim() === '') {
                $('#reg_username-error').text('Enter an username');
                $('#mobile_no-error').text('Username must');
                $('#reg_username').focus();
            } else {
                $('#reg_username-error').text('');
            }
            return false;
        } else {
            // $('#otp_div').css('display', 'none');
            $('#otp_response-error').html("").text('');
            $.ajax({
                type: "POST",
                url: 'https://devenubuntu.satbet.com/user/register/send_mobileno_otp',
                data: { mobileCode: $('#country_code').val() , mobileNo:$('#mobile_no').val() , username  : $('#reg_username').val(), [csrfName]: csrfHash },
                success: function (msg) {
                    msg = JSON.parse(msg);
                    if (msg.response === 2) {
                       $('#mobile_no-error').html('').show().html("Mobile number in use");
                    }else if(msg.response === 1){
                        $('#verify_otp').show();
                        $('#mobile_no-error').text('');
                        $('#otp_response-error').html('').html("OTP Send successfully").css('color', 'green');
                        $('#input_otp').val('');
                        $('#verify_otp').css('display','block');
                        $('#input_otp').attr('disabled',false);
                        startTimer();
                        // $('#otp_div').css('display','block');
                        $('#sendotp').text('Resend OTP');
                    }else if(msg.response === 3){
                        $('#otp_response-error').html('').html("OTP Not send successfully").css('color', 'red');
                    }else if(msg.response === 5){
                        $('#sendotp').css('display','none');
                        $('#mobile_no-error').html('')
                        $('#otp_response-error').html('').html("Exceeded daily limit for this number.").css('color', 'red');
                    }
                    setTimeout(()=>{
                        $('#otp_response-error').html('')
                    },4000);
                }
            });
        }
    });
});
$('#input_otp').on('input', function() {
    this.value = this.value.replace(/\D/g, '');
    if (this.value.length > 6) {
        this.value = this.value.slice(0,6);
    }
});

$('#mobile_no, #reg_username , #input_otp').on('onblur keyup', function(e) {
     $('#otp_response-error').html("").text('');
   if(e.target.id == 'mobile_no'){
        $('#sendotp').css('display','none').text('send OTP');
        if ($('#mobile_no').val().trim() === '') {
            $('#mobile_no-error').text('').text('Enter your mobile number');
        } else if ($('#mobile_no').val().length < 10) {
            $('#mobile_no-error').text('').text('Mobile number must be 10 digits');
        } else if(!/^[6-9]/.test($('#mobile_no').val().trim())){
            $('#mobile_no-error').text('').text("Mobile number must start with 9,8,7,6")
        }else{
            $('#sendotp').css('display','block');
            $('#mobile_no-error').text('');
        }
    }
    if(e.target.id == 'reg_username'){
        $('#reg_username').val().length === 0 
            ? $('#reg_username-error').text('Enter an username') 
            : $('#reg_username-error').text('');
    }
    if(e.target.id == 'input_otp'){
        $('#input_otp').val().length === 6 ? $('#verify_otp').css('display','block') 
            : $('#verify_otp').css('display','block');
        $('#input_otp-error').css('display','none').text('') 
    }
});
$('#verify_otp').click(()=>{
    if($('#input_otp').val()== ''){
        $('#input_otp-error').css('display','block').text('Please enter OTP')
        return false;
    }

    $.ajax({
        type: "POST",
        url: 'https://devenubuntu.satbet.com/user/register/verify_mobileno_otp',
        data: { OtpNo: $('#input_otp').val(),mobileCode: $('#country_code').val() , mobileNo:$('#mobile_no').val() , [csrfName]: csrfHash,username  : $('#reg_username').val() },
        success: function (msg) {
            msg = JSON.parse(msg);
            console.log(msg)
            if (msg.response === 2) {
                $('#mobile_no-error').show().html("Mobile number in use");
                return false;
            }else if(msg.response === 1){

                $('#otp_response-error').html('').html("OTP verified successfully").css('color', 'green');
                $('#otp_div').css('display','block');
                $('#sendotp').remove();
                $('#mobile_no-error').text('');
                $('#input_otp').attr('disabled',true);
                $('#verify_otp').attr('disabled',true).text('Verified');
                $('#mobile_no').attr('readonly',true);
                $('#timer_otp').hide();
                setTimeout(()=>{ $('#otp_response-error').hide() },3000);
                return true;
            }else if(msg.response === 3){
                $('#otp_response-error').html('').html("OTP Not send successfully");
                return false;
            }else if(msg.response === 4){
                $('#input_otp').val('');
                $('#input_otp-error').css('display','block').text('Invalid OTP')
            }
        }
    });
});

</script><!-- login script -->
<script>
	$('#loginForm').validate({
		onchange: false,
		onsubmit: true,
		onclick: false,
		onkeypress: false,
		onblur: false,
		onfocusout: false,
		rules: {
			"username": {
				required: true,
				minlength: '4',
				maxlength: '13',
			},
			"password": {
				required: true,
				minlength: '8',
				maxlength: '20',
			}
		},
		messages: {
			"username": {
				required: "Enter an username",
				minlength: 'Username must contain at least 4 characters',
				maxlength: 'Username maximum allowed characters is 13',
			},
			"password": {
				required: "Enter a password",
				minlength: 'Password must contain at least 8 characters',
      			maxlength: 'Password maximum allowed characters is 20',
			},
		},
    errorClass: "lebel-error error",  // Custom error class
    validClass: "valid",
		submitHandler: function(form, e) {
			e.preventDefault();
			$.ajax({
				url: "https://devenubuntu.satbet.com/user/login",
				type: 'POST',
				data: $('#loginForm').serialize(),
				dataType: 'json',
				beforeSend: function() {
					$('.submit-loader').css('display','block');
					$('.login-btn').css('display','none');
					$('.login-error').css('display', 'none');

				},
				success: function(data) {
					if (data.error == false) {
						srtmCommands.push({
							event: "track.user.login",
							payload: {
							action: "complete",
							userId: data.userid
						}
						});
						// Remove specific session storage keys
						sessionStorage.removeItem("_cltk");
						sessionStorage.removeItem("fcmtoken");

						window.location.href = data.redirect;

					} else {
						$('.login-error').html(data.message);
						$('.login-error').css('display', 'block');
						setTimeout(function() {
							$('.login-error').css('display', 'none');
                        }, 3000);

						$('.login-btn').css('display','block');
						$('.submit-loader').css('display','none');

					}
				}
			});
		}
	});

	$('#demoUserLogin').on('click', function(e) {
        e.preventDefault();

        if (this.id === 'demoUserLogin') {
            $('#username').val('siva002');
            $('#password').val('Test@123');
        }

			$.ajax({
			url: "https://devenubuntu.satbet.com/user/login",
			type: 'POST',
			data: $('#loginForm').serialize(),
			dataType: 'json',
			beforeSend: function() {
				$('.submit-loader').css('display','block');
				$('.login-btn').css('display','none');
				$('.login-error').css('display', 'none');

			},
			success: function(data) {
				if (data.error == false) {
					srtmCommands.push({
						event: "track.user.login",
						payload: {
						action: "complete",
						userId: data.userid
					}
					});
					// Remove specific session storage keys
					sessionStorage.removeItem("_cltk");
					sessionStorage.removeItem("fcmtoken");

					window.location.href = data.redirect;

				} else {
					$('.login-error').html(data.message);
					$('.login-error').css('display', 'block');
					setTimeout(function() {
						$('.login-error').css('display', 'none');
					}, 3000);

					$('.login-btn').css('display','block');
					$('.submit-loader').css('display','none');

				}
			}
		});
	});
</script><script>
   
function isUserRestricted($form) {
        
    var restrictedStatus = false;

    if (restrictedStatus === true) {
        // Use Swal for a professional modal alert
        Swal.fire({
            title: 'Action Restricted',
            text: 'This feature is not allowed for demo accounts. Please use a real account to access this feature.',
            icon: 'error',
            confirmButtonColor: '#d33',
            confirmButtonText: 'OK'
        });

        return true; // Indicates the user IS restricted
    }
    
    return false; // User is clear to proceed
}
</script>

