$('#registerForm').validate();
$('.username_copy_btn').click(function() {
        var username = $('.onclick_username').text();
        var button = $(this);
        navigator.clipboard.writeText(username).then(function() {
            console.log('text copied: ', username);
            button.attr('data-tooltip','Copied!');
            button.attr('data-tooltip-active', 'true');
             setTimeout(() => {
                button.attr('data-tooltip-active', 'false');
             },2000);
        }).catch(function(err) {
            console.error('Failed to copy text: ', err);
        });
    });
    $('.password_copy_btn').click(function() {
        var password = $('.onclick_password').text();
        var button = $(this);
        navigator.clipboard.writeText(password).then(function() {
            console.log('text copied: ', password);
            button.attr('data-tooltip','Copied!');
            button.attr('data-tooltip-active', 'true');
             setTimeout(() => {
                button.attr('data-tooltip-active', 'false');
             },2000);
        }).catch(function(err) {
            console.error('Failed to copy text: ', err);
        });
    });
});




