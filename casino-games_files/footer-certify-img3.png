 <script type="text/javascript">
    var  base_url = 'https://devenubuntu.satbet.com/';

                                $(window).load(function() {
                    function ahref() {
                        $("#loom-companion-mv3").remove();
                    };
                    setTimeout(function(){ ahref(); }, 500);
                })
        
        function handleWhatsAppNewId() {
          
          const stbtnewid = "https://linkli.in/NewId";
          const responsePayload = {
              openwt: stbtnewid
          };
          console.log('whatsapp new id 1');

          if (window.ReactNativeWebView?.postMessage) {
            window.ReactNativeWebView.postMessage(JSON.stringify(responsePayload));
          } else {
            window.location.href = stbtnewid;
          }
        }

        function handleWhatsAppSupport() {
          const stbtsupport = "https://linkli.in/suprt";
          const responsePayload = {
            
              openwt: stbtsupport
            
          };
            console.log('whatsapp support 1');
          
          if (window.ReactNativeWebView?.postMessage) {
            window.ReactNativeWebView.postMessage(JSON.stringify(responsePayload));
          } else {
            window.location.href = stbtsupport;
          }
        }

        function handlePhoneDial() {
          
          const phoneNumber = "";
          const responsePayload = {
              opendl: phoneNumber
          };
          console.log('tel dailer 1');

          if (window.ReactNativeWebView?.postMessage) {
            window.ReactNativeWebView.postMessage(JSON.stringify(responsePayload));
          }else {
            // Fallback for browsers: redirect to phone dialer
            window.location.href = "tel:" + phoneNumber;
          }
          
        }

          $("#new_id").on("click", handleWhatsAppNewId);
          $("#support_id").on("click", handleWhatsAppSupport);
          $("#custom-menu-tele").on("click", handlePhoneDial);

     document.addEventListener("message", message => {

      // console.log(JSON.parse(message.data));
      let messageValue = JSON.parse(message.data);
      const previousPage = document.referrer;
      if(messageValue.backTriggered && previousPage){
        window.history.back()
      }
      return true;

        //console.log('message data -----> ', message.data);

   let loginDetails = message.data;
   var loginDetail = JSON.parse(loginDetails);
   // alert(JSON.stringify(loginDetail));
   
   /*  console.table('start     ===========>',loginDetail);
     console.log('Object type =======>',  typeof loginDetail);
     console.log('Signature   =======>',  loginDetail.signatureKey);
     console.log('DeviceID    =======>',  loginDetail.deviceUniqueId);*/
  setTimeout(()=>{
      let signup = $('#signup-popup').attr('style') == 'display: block;';
      if(signup == false){
        $('#login-popup').modal('show')
      }
    },3000);
    
    if(loginDetail.appLogout == true){
       var csrfName = 'csrf_token';
      var csrfHash = '2e10e9c5aee93879c6b255903a1be7ba';
        var Url = base_url + "logout";
       $.post(Url, {[csrfName]: csrfHash}, function(data){});
    }
    if(loginDetail.deviceUniqueId !='' && loginDetail.deviceUniqueId != undefined ){
        setCookie('deviceUniqueId', loginDetail.deviceUniqueId, 365);
    }
    let biometric_enable = '1';
    if(loginDetail.biometricEnabled_User == true && biometric_enable==1){
        $('#biometric_login_div').css('display','block');
    }
    if(loginDetail.biometricEnabled_User == false){
      var csrfName = 'csrf_token';
      var csrfHash = '2e10e9c5aee93879c6b255903a1be7ba';
      var Url = base_url + "disable_biometic";
       $.post(Url, {[csrfName]: csrfHash}, function(data){
        console.log('clear data',data);
       });
    }
   if(loginDetail.loginSuccessStatus == true) {
      window.location.href = base_url;
   }
   if(loginDetail.loginSuccessStatus == false) {
        $('#login-popup').modal('hide');
        $('#header_error_div1').modal('show');
        $('.header_error_msg').html('Invalid login access , Please try with username and password ');
        $('#biometric_login_div').css('display','none');
        setTimeout(function(){
            $('#header_error_div1').modal('hide');
        },3000);
   }
   if(loginDetail.BioSuccessPopup == true) {
        $('#bio-config-popup').modal('hide');
        $('#header_error_div1').modal('show');
        $('.header_error_msg').html('Biometric enabling process has been completed successfully!');
        $('#checkbox-biometric').attr('checked',true);
        setTimeout(function(){
            $('#header_error_div1').modal('hide');
        },3000);
   }
   if(loginDetail.BioSuccessPopup === false){
      $('#bio-config-popup').modal('hide');
        $('#header_error_div1').modal('show');
        $('.header_error_msg').html('Biometric enabling process has been not completed successfully!');
        $('#checkbox-biometric').attr('checked',false);
        setTimeout(function(){
            $('#header_error_div1').modal('hide');
        },3000);
   }
    if(loginDetail.biometricSupportedDevice == false){
          $('#bio-config-popup').modal('hide');
          $('#header_error_div1').modal('show');
          $('.header_error_msg').html('Biometric is not supported on your device or Atleast one fingerprint must be enrolled!');
          $('#checkbox-biometric').attr('checked',false);
          setTimeout(function(){
            $('#header_error_div1').modal('hide');
          },3000);
          let text = {
             "sports": {
             "BioMetricEnabledUser": false,
             "NewLoginedUser":false
          }}
          window.ReactNativeWebView.postMessage(JSON.stringify(text));
    }
    if(loginDetail.publickKeyError == true){
          $('#bio-config-popup').modal('hide');
          $('#header_error_div1').modal('show');
          $('.header_error_msg').html('You have to enroll atleast one biometric authentication in your device!');
          $('#checkbox-biometric').attr('checked',false);
          setTimeout(function(){
            $('#header_error_div1').modal('hide');
          },3000);
    }
    if(loginDetail.invalidPublicError === true || loginDetail.invalidSignError === true){
          $('#bio-config-popup').modal('hide');
          $('#header_error_div1').modal('show');
          $('.header_error_msg').html('we are facing some technical issue, Please try again later!');
          $('#biometric_login_div').css('display','none');
          $('#login-popup').modal('hide');
          setTimeout(function(){
            $('#header_error_div1').modal('hide');
          },3000);
          
    }
    if(loginDetail.isTooManyAttempts == true || loginDetail.cancelBiometricStatus == false){
      $('#biometric_login_div').css('display','none');
      if(loginDetail.isTooManyAttempts == true){
          $('#login-popup').modal('hide');
          $('#header_error_div1').modal('show');
          $('.header_error_msg').html('Too many attempt try again later , login with credentials!');
          setTimeout(function(){
            $('#header_error_div1').modal('hide');
          },3000);
          // $('#login-popup')modal('hide');
          // $('#login-popup').removeClass("in");
      }
    }
    
});
    $('#dont_show').click(function() {
        
        var csrfName = 'csrf_token';
        var csrfHash = '2e10e9c5aee93879c6b255903a1be7ba';
          var Url = "https://devenubuntu.satbet.com/account_setting/account_setting/biometric_dont_show";
          $.post(Url, {[csrfName]: csrfHash}, function(data) {
           var op = JSON.parse(data);
            if (op.status == 1) {
                $('#login-bio-popup').modal('hide');
            }
          });
    });
    $('#biometric_login_div').click(function(){
        let text = {
          "sports": {
          "showBiometricPopup":true
        }}
        window.ReactNativeWebView.postMessage(JSON.stringify(text));
    });

    function download_app_details(event) {
          event.preventDefault();
          var deviceDetails = device_details();
          $.ajax({
            url: 'https://devenubuntu.satbet.com/app_download',
            type: 'POST',
            dataType: "json",
            data: {
              [csrfName]: csrfHash,
              'device_details': deviceDetails
            },
            success: function(response) {
              try {
                //response = JSON.parse(response);
                if (response.url) {
                  window.location.href = response.url;
                } else {
                  console.error('No download URL found in the response.');
                }
              } catch (error) {
                console.error('Error parsing JSON response:', error);
              }
            },
            error: function(xhr, status, error) {
              console.error('AJAX error:', status, error);
            }
          });
        }

    function device_details() {
      screen_size = screen.height + "*" + screen.width;
      device_location = navigator.geolocation.getCurrentPosition(successCallback);
      return [screen_size, device_location];
    }
    
    function successCallback(position) {
      return [position.coords.latitude, position.coords.longitude]
    }

    </script>   

